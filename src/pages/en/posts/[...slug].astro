---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts
    .filter(p => p.id.split('/')[1] === 'en')
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

  return posts.map((post) => {
    const [cat, , slug] = post.id.split('/');
    const sameCat = posts.filter(p => p.id.split('/')[0] === cat);
    const i = sameCat.indexOf(post);
    const prev = i > 0 ? sameCat[i - 1] : null;
    const next = i < sameCat.length - 1 ? sameCat[i + 1] : null;
    return { params: { slug: `${cat}/${slug}` }, props: { post, prev, next } };
  });
}

const { post, prev, next } = Astro.props;

const getPostUrl = (p: NonNullable<typeof prev>) => {
  const [cat, , slug] = p.id.split('/');
  return `/en/posts/${cat}/${slug}/`;
};
const { Content } = await render(post);
const t = useTranslations('en');

const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout pageTitle={post.data.title} locale="en">
  <article class="post">
    <div class="post-header">
      <a href="/en/" class="back">{t('post.back')}</a>
      <h1>{post.data.title}</h1>
      <p class="post-date">{formatDate(post.data.pubDate)}</p>
    </div>
    <div class="post-content">
      <Content />
    </div>
    <nav class="post-nav">
      {prev && (
        <a href={getPostUrl(prev)} class="post-nav-link post-nav-prev">
          <span class="post-nav-label">{t('post.prev')}</span>
          <span class="post-nav-title">{prev.data.title}</span>
        </a>
      )}
      {next && (
        <a href={getPostUrl(next)} class="post-nav-link post-nav-next">
          <span class="post-nav-label">{t('post.next')}</span>
          <span class="post-nav-title">{next.data.title}</span>
        </a>
      )}
    </nav>
  </article>
</Layout>

<style>
  .post {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .post-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 32px;
    margin-bottom: 40px;
  }

  .back {
    display: inline-block;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .back:hover { opacity: 0.7; }

  h1 {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .post-date {
    font-size: 12px;
    color: var(--muted);
  }

  .post-content {
    font-size: 14px;
    line-height: 1.8;
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    font-weight: 700;
    margin: 2em 0 0.75em;
  }

  .post-content :global(h2) { font-size: 18px; }
  .post-content :global(h3) { font-size: 15px; }

  .post-content :global(p) { margin-bottom: 1.2em; }

  .post-content :global(code) {
    background: var(--border);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 13px;
  }

  .post-content :global(pre) {
    background: var(--fg);
    color: var(--bg);
    padding: 20px 24px;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 13px;
    line-height: 1.6;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.2em;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--border);
    padding-left: 16px;
    color: var(--muted);
    margin: 1.5em 0;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 45%;
  }

  .post-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .post-nav-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .post-nav-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
  }

  .post-nav-link:hover .post-nav-title { opacity: 0.7; }
</style>
