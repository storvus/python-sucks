---
import { getCollection } from 'astro:content';
import { getCategoryLabel, getPostCategory } from '../data/categories';
import { useTranslations, type Locale } from '../i18n/index';

interface Props {
  limit?: number;
  locale?: Locale;
}
const { limit = 5, locale = 'ru' } = Astro.props;
const t = useTranslations(locale);

const allPosts = (await getCollection('posts'))
  .filter(p => p.id.split('/')[1] === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const posts = allPosts.slice(0, limit);
const hasMore = allPosts.length > limit;

const dateLocale = locale === 'ru' ? 'ru-RU' : 'en-US';
const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString(dateLocale, { day: 'numeric', month: 'short', year: 'numeric' });
---

<section class="posts-section">
  <p class="section-label">{t('blog.latest')}</p>
  <ul class="post-list">
    {posts.map(post => {
      const category = getPostCategory(post.id);
      const [cat, , slug] = post.id.split('/');
      const href = locale === 'ru'
        ? `/posts/${cat}/${slug}/`
        : `/en/posts/${cat}/${slug}/`;
      return (
        <li>
          <a href={href} class="post-item">
            <div class="post-row">
              <h2 class="post-title">{post.data.title}</h2>
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              <span class="post-arrow" aria-hidden="true">→</span>
            </div>
            {category && (
              <span class="post-cat">{getCategoryLabel(category, locale)}</span>
            )}
            <p class="post-desc">{post.data.description}</p>
          </a>
        </li>
      );
    })}
  </ul>
  {hasMore && (
    <div class="view-all">
      <a href={locale === 'ru' ? '/all-posts' : '/en/all-posts'}>{t('blog.view-all')}</a>
    </div>
  )}
</section>

<style>
  .posts-section {
    border-top: 1px solid var(--border);
    padding: 48px 24px 0;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-label {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-bottom: 28px;
  }

  .post-list {
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px solid var(--border);
  }

  .post-item {
    display: block;
    padding: 22px 0;
    color: inherit;
  }

  .post-item:hover { opacity: 1; }
  .post-item:hover .post-title { opacity: 0.65; }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
  }

  .post-title {
    font-size: 15px;
    font-weight: 700;
    flex: 1;
    letter-spacing: 0.01em;
    line-height: 1.4;
    transition: opacity 0.15s;
  }

  .post-date {
    color: var(--muted);
    font-size: 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-arrow {
    color: var(--muted);
    font-size: 15px;
    flex-shrink: 0;
  }

  .post-cat {
    display: inline-block;
    font-size: 11px;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 1px 8px;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .post-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .view-all {
    text-align: center;
    padding: 36px 0;
    font-size: 13px;
  }
</style>
