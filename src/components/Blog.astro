---
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
}
const { limit = 5 } = Astro.props;

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, limit);

const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
---

<section class="posts-section">
  <p class="section-label">&gt; последние статьи</p>
  <ul class="post-list">
    {posts.map(post => (
      <li>
        <a href={`/posts/${post.id}/`} class="post-item">
          <div class="post-row">
            <h2 class="post-title">{post.data.title}</h2>
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            <span class="post-arrow" aria-hidden="true">→</span>
          </div>
          <p class="post-desc">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .posts-section {
    border-top: 1px solid var(--border);
    padding: 48px 24px 0;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-label {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-bottom: 28px;
  }

  .post-list {
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px solid var(--border);
  }

  .post-item {
    display: block;
    padding: 22px 0;
    color: inherit;
  }

  .post-item:hover { opacity: 1; }
  .post-item:hover .post-title { opacity: 0.65; }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
  }

  .post-title {
    font-size: 15px;
    font-weight: 700;
    flex: 1;
    letter-spacing: 0.01em;
    line-height: 1.4;
    transition: opacity 0.15s;
  }

  .post-date {
    color: var(--muted);
    font-size: 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-arrow {
    color: var(--muted);
    font-size: 15px;
    flex-shrink: 0;
  }

  .post-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .view-all {
    text-align: center;
    padding: 36px 0;
    font-size: 13px;
  }
</style>
