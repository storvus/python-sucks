---
import { getCollection } from 'astro:content';

const getExcerpt = (body: string) => body.split('<!-- more -->')[0].trim()
const posts = await getCollection('posts');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

{
  posts.map((post) => (
  <article>
      <div class="post-image">
          <div class="post-heading">
              <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
              <span class="blog-date">{new Date(post.data.pubDate).toDateString()}</span>
          </div>
      </div>
      {post.data.description}
      <div class="bottom-article">
          <ul class="meta-post">
              <li class="text-center">
                  {
                    post.data.tags.map(tag => (
                      <a href={`/tags/${tag}`}>#{tag}</a>
                    ))
                  }
              </li>
              <li class="text-right">
                  <a href={`/posts/${post.id}/`}>ПОДРОБНЕЕ</a>
              </li>
              <!--<li>-->
              <!--    <a href="#" data-placement="top" title="behance"><i class="fa fa-behance"></i></a>-->
              <!--    <a href="#" data-placement="top" title="Twitter"><i class="fa fa-twitter"></i></a>-->
              <!--    <a href="#" data-placement="top" title="google"><i class="fa fa-google-plus"></i></a>-->
              <!--</li>-->
          </ul>
      </div>
  </article>
    ))
  }
